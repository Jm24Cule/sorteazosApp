# Token de acceso de larga duración de Instagram Graph API
# Obtenerlo desde: https://developers.facebook.com/
INSTAGRAM_TOKEN=your_long_lived_token_here

# ID numérico de tu cuenta de Instagram Business
# Obtenerlo desde: GET https://graph.facebook.com/v19.0/me/accounts (con el token)
INSTAGRAM_USER_ID=your_instagram_user_id_here
